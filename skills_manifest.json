      "requires_venv": false,
      "parameters": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string",
            "description": "操作類型。 start=開始新的學習單引導流程、 continue=繼續當前進度、 summary=彙整目前填寫成果、 export=產出學習成果報告\n",
            "enum": [
              "start",
