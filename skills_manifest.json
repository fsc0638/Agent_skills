              "en",
              "vi",
              "ja"
            ]
          },
          "export_format": {
            "type": "string",
            "description": "[export] 輸出格式",
            "enum": [
              "text",
              "pdf",
              "docx"
            ]
          }
        },
        "required": [
          "action"
        ]
      }
